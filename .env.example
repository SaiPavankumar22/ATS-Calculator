# Nebius AI Studio (required)
NEBIUS_API_KEY=your_nebius_api_key_here

# Default model — must be a Nebius-supported model
DEFAULT_MODEL=google/gemma-3-27b-it

# GitHub API (optional — increases rate limit from 60/hour to 5000/hour)
GITHUB_TOKEN=your_github_token_here

# Server settings
HOST=0.0.0.0
PORT=5000
DEBUG=false
LOG_LEVEL=INFO
OPEN_BROWSER=false
MAX_FILE_SIZE=10485760
CORS_ORIGINS=*

# Cache parsed resume and GitHub data locally (recommended for development)
DEVELOPMENT_MODE=true
