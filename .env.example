# LLM Provider Configuration
# Options: "ollama" or "nebius"
LLM_PROVIDER=ollama

# Default model to use
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Nebius: "google/gemma-3-27b-it", "meta-llama/Meta-Llama-3.1-70B-Instruct", etc.
DEFAULT_MODEL=gemma3:4b

# Nebius AI Studio API Key (required if using Nebius provider)
NEBIUS_API_KEY=your_nebius_api_key_here

# Server settings
HOST=0.0.0.0
PORT=5000
DEBUG=false
LOG_LEVEL=INFO
OPEN_BROWSER=false
MAX_FILE_SIZE=10485760
CORS_ORIGINS=*
